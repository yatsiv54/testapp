    "services": [
      {
        "serviceName": "CameraService",
        "serviceType": "device",
        "primaryPurpose": "Capture photos for expenses and profile",
        "dataReadFrom": "camera",
        "dataWriteTo": "localStorage",
        "cachingPolicy": "persistent",
        "offlineBehavior": "full"
      },
      {
        "serviceName": "LocalStorageService",
        "serviceType": "storage",
        "primaryPurpose": "Store all user data and images",
        "dataReadFrom": "memory",
        "dataWriteTo": "device",
        "cachingPolicy": "persistent",
        "offlineBehavior": "full"
      },
      {
        "serviceName": "AnalyticsService",
        "serviceType": "logic",
        "primaryPurpose": "Calculate savings, leftovers, and trends",
        "dataReadFrom": "localStorage",
        "dataWriteTo": "none",
        "cachingPolicy": "none",
        "offlineBehavior": "full"
      }
    ],
    "validation": {
      "globalRules": {
        "constraints": "No empty required fields, no null values",
        "errorMessage": "Field is required",
        "systemBehavior": "Block submission, highlight field"
      },
      "textFieldRules": {
        "constraints": "Min 2, max 40 chars, no special symbols except dash/space",
        "errorMessage": "Invalid text input",
        "systemBehavior": "Show inline error, block submission"
      },
      "numericFieldRules": {
        "constraints": "Positive numbers only, max 6 digits",
        "errorMessage": "Invalid amount",
        "systemBehavior": "Show inline error, block submission"
      },
      "dateFieldRules": {
        "constraints": "Valid date, not in future",
        "errorMessage": "Invalid date",
        "systemBehavior": "Show inline error, block submission"
      },
      "imageRules": {
        "constraints": "JPEG/PNG, max 5MB, must be photo (not blank)",
        "errorMessage": "Invalid or missing photo",
        "systemBehavior": "Show inline error, block submission"
      },
      "selectionRules": {
        "constraints": "Must select from list",
        "errorMessage": "Selection required",
        "systemBehavior": "Show inline error, block submission"
      },
      "errorHandlingStrategy": "Show error dialog, allow retry, log error",
      "formSubmissionPolicy": "Block submission on any validation error, focus first invalid field"
    },
    "components": [
      "ExpenseCard",
      "PhotoPicker",
      "WheelWidget",
      "AnalyticsChart",
      "ProfileAvatar",
      "SettingsList",
      "CurrencyPicker",
      "NotificationBanner"
    ],
    "ratingFlow": {
      "type": "native",
      "implementation": "in_app_review",
      "threshold": 4,
      "feedbackForm": false,
      "validationRules": [],
      "redirectCondition": "Prompt native review after 10 uses"
    },
    "notificationFlows": [
      {
        "notificationType": "reminder",
        "title": "Don’t forget to log today’s expenses!",
        "body": "Track your daily spending and grow your leftovers.",
        "triggerCondition": "Daily at 8pm if no expense added",
        "frequency": "daily",
        "deepLinkDestination": "CreateExpenseScreen",
        "relatedFeature": "Expense Tracking"
      },
      {
        "notificationType": "wheelReady",
        "title": "Wheel mode is ready!",
        "body": "Spin the wheel to multiply your leftovers today.",
        "triggerCondition": "Once per day at 7pm",
        "frequency": "daily",
        "deepLinkDestination": "WheelScreen",
        "relatedFeature": "Wheel Mode"
      }
    ]
  }
